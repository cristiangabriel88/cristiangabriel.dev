{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/build-on-jsx.js",
            "timeout": 60,
            "statusMessage": "Rebuilding root *.js from JSX…"
          }
        ]
      }
    ]
  }
}
